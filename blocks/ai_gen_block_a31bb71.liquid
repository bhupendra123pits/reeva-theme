{% doc %}
  @prompt
    create an banner section able to add multiple images which is move horizontally
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrolling-banner-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    display: block;
  }

  .ai-scrolling-banner__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    animation: ai-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-scrolling-banner__track-{{ ai_gen_id }}:hover {
    animation-play-state: {{ block.settings.pause_on_hover | default: true }};
  }

  .ai-scrolling-banner__image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width }}px;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-scrolling-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-scrolling-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-scrolling-banner__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-{{ block.settings.image_width }}px * {{ block.settings.images.count }} - {{ block.settings.image_gap }}px * {{ block.settings.images.count }}));
    }
  }

  @media screen and (max-width: 749px) {
    .ai-scrolling-banner__image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_width | times: 0.7 }}px;
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }

    @keyframes ai-scroll-{{ ai_gen_id }} {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(calc(-{{ block.settings.image_width | times: 0.7 }}px * {{ block.settings.images.count }} - {{ block.settings.image_gap }}px * {{ block.settings.images.count }}));
      }
    }
  }
{% endstyle %}

<scrolling-banner-{{ ai_gen_id }} class="ai-scrolling-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scrolling-banner__track-{{ ai_gen_id }}">
    {% if block.settings.images.count > 0 %}
      {% for image in block.settings.images %}
        <div class="ai-scrolling-banner__image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ image | image_url: width: 800 }}"
            alt="{{ image.alt | escape }}"
            class="ai-scrolling-banner__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image_width }}"
            height="{{ block.settings.image_height }}"
          >
        </div>
      {% endfor %}
      {% for image in block.settings.images %}
        <div class="ai-scrolling-banner__image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ image | image_url: width: 800 }}"
            alt="{{ image.alt | escape }}"
            class="ai-scrolling-banner__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image_width }}"
            height="{{ block.settings.image_height }}"
          >
        </div>
      {% endfor %}
    {% else %}
      {% for i in (1..6) %}
        <div class="ai-scrolling-banner__image-wrapper-{{ ai_gen_id }}">
          <div class="ai-scrolling-banner__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        </div>
      {% endfor %}
      {% for i in (1..6) %}
        <div class="ai-scrolling-banner__image-wrapper-{{ ai_gen_id }}">
          <div class="ai-scrolling-banner__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</scrolling-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollingBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-scrolling-banner__track-{{ ai_gen_id }}');
        
        if (this.track) {
          const pauseOnHover = {{ block.settings.pause_on_hover | default: true }};
          
          if (pauseOnHover) {
            this.track.addEventListener('mouseenter', () => {
              this.track.style.animationPlayState = 'paused';
            });
            
            this.track.addEventListener('mouseleave', () => {
              this.track.style.animationPlayState = 'running';
            });
          }
        }
      }
    }

    customElements.define('scrolling-banner-{{ ai_gen_id }}', ScrollingBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scrolling banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "images",
      "label": "Images"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Gap between images",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f6f2ec"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Scrolling banner"
    }
  ]
}
{% endschema %}
