  "presets": [
    {
      "name": "Reeva Gifting",
      "blocks": [
        {
          "type": "gift_card",
          "settings": {
            "badge": "For Her",
            "title": "Gifts for Her",
            "text": "Elegant pieces for someone special."
          }
