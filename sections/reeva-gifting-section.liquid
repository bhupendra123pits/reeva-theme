      "label": "Card background",
      "default": "#f8f2e8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#282828"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#267870"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border color",
      "default": "#eadcc7"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "gift_card",
      "name": "Gift card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Gift image"
        },
        {
          "type": "text",
          "id": "badge",
