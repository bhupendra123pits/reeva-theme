{% comment %}
  Reeva Hero Banner Section
  — Matches the "New Arrivals / Fresh sparkle, just added" style
  — Fully customisable via section settings: text, colors, background image, overlay
{% endcomment %}

<section
  class="reeva-hero section-{{ section.id }}"
  style="
    --hero-bg:            {{ section.settings.background_color }};
    --hero-overlay:       {{ section.settings.overlay_color }};
    --hero-overlay-op:    {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-kicker-color:  {{ section.settings.kicker_color }};
    --hero-heading-color: {{ section.settings.heading_color }};
    --hero-text-color:    {{ section.settings.text_color }};
    --hero-btn-hover:     {{ section.settings.button_hover_color }};
    --hero-min-height:    {{ section.settings.section_height }}px;
    --hero-pt:            {{ section.settings.padding_top }}px;
    --hero-pb:            {{ section.settings.padding_bottom }}px;
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
    {% endif %}
  "
>
  {%- comment -%} Colour/image overlay {%- endcomment -%}
  <div class="reeva-hero__overlay"></div>

  <div class="reeva-hero__inner">
    {%- if section.settings.kicker != blank -%}
      <p class="reeva-hero__kicker">
        <span class="reeva-hero__kicker-line"></span>
        {{- section.settings.kicker -}}
        <span class="reeva-hero__kicker-icon" aria-hidden="true">&#x2192;</span>
        <span class="reeva-hero__kicker-line"></span>
      </p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="reeva-hero__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="reeva-hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
      <a href="{{ section.settings.button_url }}" class="reeva-hero__btn">
        {{- section.settings.button_label -}}
      </a>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ─── STYLES ──────────────────────────────────────────────── {%- endcomment -%}
<style>
 
  .section-{{ section.id }}.reeva-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--hero-min-height, 420px);
    padding-top: var(--hero-pt, 80px);
    padding-bottom: var(--hero-pb, 80px);
    background-color: var(--hero-bg, #f9f3ea);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
    text-align: center;
  }

  /* ── Overlay ───────────────────────────────────────────────────────── */
  .section-{{ section.id }} .reeva-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--hero-overlay, #fffaf2);
    opacity: var(--hero-overlay-op, 0.55);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Content ───────────────────────────────────────────────────────── */
  .section-{{ section.id }} .reeva-hero__inner {
    position: relative;
    z-index: 2;
    width: min(100% - 40px, 860px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    transform: translateY(-62px);
  }

  /* ── Kicker ────────────────────────────────────────────────────────── */
  .section-{{ section.id }} .reeva-hero__kicker {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hero-kicker-color, #1a5c50);
    margin: 0;
  }

  .section-{{ section.id }} .reeva-hero__kicker-line {
    display: block;
    width: 40px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  .section-{{ section.id }} .reeva-hero__kicker-icon {
    font-size: 14px;
  }

  /* ── Heading ───────────────────────────────────────────────────────── */
  .section-{{ section.id }} .reeva-hero__heading {
    margin: 0;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--hero-heading-color, #1a3c34);
  }

  /* ── Subheading ────────────────────────────────────────────────────── */
  .section-{{ section.id }} .reeva-hero__subheading {
    margin: 0;
    max-width: 560px;
    font-size: clamp(14px, 1.8vw, 17px);
    line-height: 1.65;
    color: var(--hero-text-color, #4a4a4a);
  }

  /* ── Button ────────────────────────────────────────────────────────── */
  .section-{{ section.id }} .reeva-hero__btn {
    display: inline-block;
    margin-top: 8px;
    padding: 14px 32px;
    background: #3f8984;
    border: 1.5px solid #267870;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
    border-radius:4px;
  }

  .section-{{ section.id }} .reeva-hero__btn:hover {
    background: #267870;
    border-color: var(--hero-btn-hover, #c9a84c);
    color: #fff;
  }

  /* ── Mobile ────────────────────────────────────────────────────────── */
  @media (max-width: 749px) {
    .section-{{ section.id }}.reeva-hero {
      text-align: center;
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>

{%- comment -%} ─── SCHEMA ─────────────────────────────────────────────── {%- endcomment -%}
{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "reeva-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (small label above heading)",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fresh sparkle, just added"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the latest jewellery pieces crafted for everyday elegance and special moments."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop New Arrivals"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour (fallback)",
      "default": "#f9f3ea"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Image overlay colour",
      "default": "#fffaf2"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "header",
      "content": "Typography colours"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Kicker colour",
      "default": "#1a5c50"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#1a3c34"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subheading colour",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover colour",
      "default": "#c9a84c"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Minimum section height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 420
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
