{% comment %}
  Reeva.life - Occasion Grid Section
  File: sections/reeva-occasion-grid.liquid
{% endcomment %}

<section
  class="reeva-occasion-section section-{{ section.id }}"
  style="
    --reeva-bg: {{ section.settings.background_color }};
    --reeva-card-bg: {{ section.settings.card_background }};
    --reeva-heading: {{ section.settings.heading_color }};
    --reeva-text: {{ section.settings.text_color }};
    --reeva-accent: {{ section.settings.accent_color }};
    --reeva-border: {{ section.settings.border_color }};
    --reeva-top: {{ section.settings.padding_top }}px;
    --reeva-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="reeva-occasion-container">

    {% if section.settings.kicker != blank %}
      <div class="reeva-occasion-kicker">{{ section.settings.kicker }}</div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="reeva-occasion-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="reeva-occasion-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="reeva-occasion-grid reeva-occasion-layout-{{ section.settings.layout_style }}">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="reeva-occasion-card {% if block.settings.large_card %}reeva-occasion-large{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="reeva-occasion-image-wrap">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1100
                | image_tag:
                  loading: 'lazy',
                  class: 'reeva-occasion-image',
                  widths: '400, 600, 800, 1000, 1100',
                  sizes: '(max-width: 749px) 90vw, (max-width: 989px) 45vw, 33vw',
                  alt: block.settings.title
              }}
            {% else %}
              <div class="reeva-occasion-placeholder">
                {{ 'collection-2' | placeholder_svg_tag }}
              </div>
            {% endif %}

            <div class="reeva-occasion-overlay"></div>

            {% if block.settings.badge != blank %}
              <span class="reeva-occasion-badge">{{ block.settings.badge }}</span>
            {% endif %}

            <div class="reeva-occasion-content">
              {% if block.settings.title != blank %}
                <h3>{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.text != blank %}
                <p>{{ block.settings.text }}</p>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <span class="reeva-occasion-link">
                  {{ block.settings.button_label }}
                  <span aria-hidden="true">→</span>
                </span>
              {% endif %}
            </div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.settings.main_button_label != blank %}
      <div class="reeva-occasion-main-btn-wrap">
        <a href="{{ section.settings.main_button_link | default: '#' }}" class="reeva-occasion-main-btn">
          {{ section.settings.main_button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  .section-{{ section.id }} {
    background: var(--reeva-bg);
    padding-top: var(--reeva-top);
    padding-bottom: var(--reeva-bottom);
  }

  .section-{{ section.id }} .reeva-occasion-container {
    width: min(100% - 32px, 1320px);
    margin: 0 auto;
    text-align: center;
  }

  .section-{{ section.id }} .reeva-occasion-kicker {
    font-family: Verdana, Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--reeva-accent);
    margin-bottom: 18px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }

  .section-{{ section.id }} .reeva-occasion-kicker::before,
  .section-{{ section.id }} .reeva-occasion-kicker::after {
    content: "";
    width: 70px;
    height: 1px;
    background: rgba(184, 145, 85, 0.55);
    display: block;
  }

  .section-{{ section.id }} .reeva-occasion-heading {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.08;
    font-weight: 500;
    color: var(--reeva-heading);
    margin: 0 0 14px;
  }

  .section-{{ section.id }} .reeva-occasion-subheading {
    font-family: Verdana, Arial, sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: var(--reeva-text);
    max-width: 660px;
    margin: 0 auto 42px;
  }

  .section-{{ section.id }} .reeva-occasion-grid {
    display: grid;
    gap: 24px;
  }

  .section-{{ section.id }} .reeva-occasion-layout-equal {
    grid-template-columns: repeat(4, 1fr);
  }

  .section-{{ section.id }} .reeva-occasion-layout-bento {
    grid-template-columns: repeat(4, 1fr);
    grid-auto-flow: dense;
  }

  .section-{{ section.id }} .reeva-occasion-layout-bento .reeva-occasion-large {
    grid-column: span 2;
  }

  .section-{{ section.id }} .reeva-occasion-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--reeva-border);
    background: var(--reeva-card-bg);
    box-shadow: 0 12px 30px rgba(37, 37, 37, 0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .section-{{ section.id }} .reeva-occasion-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 38px rgba(37, 37, 37, 0.1);
    border-color: rgba(38, 120, 112, 0.35);
  }

  .section-{{ section.id }} .reeva-occasion-image-wrap {
    position: relative;
    min-height: 390px;
    height: 100%;
    overflow: hidden;
    background: #f5efe5;
  }

  .section-{{ section.id }} .reeva-occasion-layout-equal .reeva-occasion-image-wrap {
    aspect-ratio: 0.82 / 1;
  }

  .section-{{ section.id }} .reeva-occasion-layout-bento .reeva-occasion-image-wrap {
    aspect-ratio: 1 / 1.12;
  }

  .section-{{ section.id }} .reeva-occasion-layout-bento .reeva-occasion-large .reeva-occasion-image-wrap {
    aspect-ratio: 1.72 / 1;
  }

  .section-{{ section.id }} .reeva-occasion-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .section-{{ section.id }} .reeva-occasion-card:hover .reeva-occasion-image {
    transform: scale(1.045);
  }

  .section-{{ section.id }} .reeva-occasion-placeholder,
  .section-{{ section.id }} .reeva-occasion-placeholder svg {
    width: 100%;
    height: 100%;
  }

  .section-{{ section.id }} .reeva-occasion-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5efe5;
  }

  .section-{{ section.id }} .reeva-occasion-placeholder svg {
    opacity: 0.35;
  }

  .section-{{ section.id }} .reeva-occasion-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.04) 0%,
      rgba(0, 0, 0, 0.12) 45%,
      rgba(0, 0, 0, 0.58) 100%
    );
    z-index: 1;
  }

  .section-{{ section.id }} .reeva-occasion-badge {
    position: absolute;
    top: 18px;
    left: 18px;
    z-index: 2;
    background: rgba(255, 250, 242, 0.92);
    color: var(--reeva-accent);
    font-family: Verdana, Arial, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(234, 220, 199, 0.8);
  }

  .section-{{ section.id }} .reeva-occasion-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 28px 24px;
    text-align: left;
  }

  .section-{{ section.id }} .reeva-occasion-content h3 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(26px, 2.2vw, 36px);
    line-height: 1.12;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 10px;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
  }

  .section-{{ section.id }} .reeva-occasion-content p {
    font-family: Verdana, Arial, sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.88);
    margin: 0 0 18px;
    max-width: 360px;
  }

  .section-{{ section.id }} .reeva-occasion-link {
    font-family: Verdana, Arial, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.75);
    padding-bottom: 4px;
  }

  .section-{{ section.id }} .reeva-occasion-main-btn-wrap {
    margin-top: 38px;
  }

  .section-{{ section.id }} .reeva-occasion-main-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 38px;
    border-radius: 6px;
    background: var(--reeva-accent);
    color: #ffffff;
    font-family: Verdana, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .reeva-occasion-main-btn:hover {
    opacity: 0.92;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .reeva-occasion-layout-equal,
    .section-{{ section.id }} .reeva-occasion-layout-bento {
      grid-template-columns: repeat(2, 1fr);
    }

    .section-{{ section.id }} .reeva-occasion-layout-bento .reeva-occasion-large {
      grid-column: span 2;
    }

    .section-{{ section.id }} .reeva-occasion-image-wrap {
      min-height: 340px;
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: calc(var(--reeva-top) * 0.7);
      padding-bottom: calc(var(--reeva-bottom) * 0.7);
    }

    .section-{{ section.id }} .reeva-occasion-container {
      width: min(100% - 24px, 1320px);
    }

    .section-{{ section.id }} .reeva-occasion-kicker {
      font-size: 11px;
      letter-spacing: 3px;
      gap: 10px;
      margin-bottom: 14px;
    }

    .section-{{ section.id }} .reeva-occasion-kicker::before,
    .section-{{ section.id }} .reeva-occasion-kicker::after {
      width: 34px;
    }

    .section-{{ section.id }} .reeva-occasion-heading {
      font-size: 34px;
    }

    .section-{{ section.id }} .reeva-occasion-subheading {
      font-size: 14px;
      margin-bottom: 28px;
    }

    .section-{{ section.id }} .reeva-occasion-layout-equal,
    .section-{{ section.id }} .reeva-occasion-layout-bento {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .section-{{ section.id }} .reeva-occasion-layout-bento .reeva-occasion-large {
      grid-column: span 1;
    }

    .section-{{ section.id }} .reeva-occasion-image-wrap,
    .section-{{ section.id }} .reeva-occasion-layout-equal .reeva-occasion-image-wrap,
    .section-{{ section.id }} .reeva-occasion-layout-bento .reeva-occasion-image-wrap,
    .section-{{ section.id }} .reeva-occasion-layout-bento .reeva-occasion-large .reeva-occasion-image-wrap {
      aspect-ratio: 1.1 / 1;
      min-height: 310px;
    }

    .section-{{ section.id }} .reeva-occasion-content {
      padding: 24px 20px;
    }

    .section-{{ section.id }} .reeva-occasion-content h3 {
      font-size: 28px;
    }

    .section-{{ section.id }} .reeva-occasion-main-btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Reeva Occasion Grid",
  "tag": "section",
  "class": "reeva-occasion-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Small top heading",
      "default": "Shop by Occasion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Jewellery for every moment"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover elegant pieces for daily wear, celebrations, gifting and meaningful occasions."
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "default": "bento",
      "options": [
        {
          "value": "bento",
          "label": "Bento layout"
        },
        {
          "value": "equal",
          "label": "Equal cards"
        }
      ]
    },
    {
      "type": "text",
      "id": "main_button_label",
      "label": "Main button label",
      "default": "Explore Occasion Edit"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fffaf2"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#f8f2e8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#282828"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#267870"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border color",
      "default": "#eadcc7"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "occasion",
      "name": "Occasion card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Occasion image"
        },
        {
          "type": "checkbox",
          "id": "large_card",
          "label": "Make this card large",
          "default": false
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "default": "Curated"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Occasion title",
          "default": "Everyday Elegance"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Occasion description",
          "default": "Minimal jewellery made for daily wear and effortless styling."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Link label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Occasion link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reeva Occasion Grid",
      "blocks": [
        {
          "type": "occasion",
          "settings": {
            "large_card": true,
            "badge": "Daily Wear",
            "title": "Everyday Elegance",
            "text": "Subtle rings, earrings and pendants designed for daily comfort.",
            "button_label": "Shop Everyday"
          }
        },
        {
          "type": "occasion",
          "settings": {
            "badge": "Office Edit",
            "title": "Workwear Jewellery",
            "text": "Polished pieces that feel refined, light and easy to style.",
            "button_label": "Shop Workwear"
          }
        },
        {
          "type": "occasion",
          "settings": {
            "badge": "Festive",
            "title": "Festive Glow",
            "text": "Elegant jewellery for celebrations, rituals and family gatherings.",
            "button_label": "Shop Festive"
          }
        },
        {
          "type": "occasion",
          "settings": {
            "badge": "Gifting",
            "title": "Meaningful Gifts",
            "text": "Thoughtful picks for birthdays, anniversaries and special moments.",
            "button_label": "Shop Gifts"
          }
        },
        {
          "type": "occasion",
          "settings": {
            "large_card": true,
            "badge": "Celebration",
            "title": "Wedding & Party",
            "text": "Statement pieces created for memorable occasions and timeless photographs.",
            "button_label": "Shop Celebration"
          }
        }
      ]
    }
  ]
}
{% endschema %}