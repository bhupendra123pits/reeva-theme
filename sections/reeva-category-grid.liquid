{% comment %}
  Reeva.life - Custom Category Grid Section
  File: sections/reeva-category-grid.liquid
{% endcomment %}

<section
  class="reeva-category-grid section-{{ section.id }}"
  style="
    --reeva-bg: {{ section.settings.background_color }};
    --reeva-heading: {{ section.settings.heading_color }};
    --reeva-text: {{ section.settings.text_color }};
    --reeva-accent: {{ section.settings.accent_color }};
    --reeva-card-bg: {{ section.settings.card_background }};
    --reeva-border: {{ section.settings.border_color }};
    --reeva-top: {{ section.settings.padding_top }}px;
    --reeva-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="reeva-category-container">

    {% if section.settings.kicker != blank %}
      <div class="reeva-category-kicker">{{ section.settings.kicker }}</div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="reeva-category-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="reeva-category-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="reeva-category-grid-wrap reeva-grid-{{ section.settings.desktop_columns }}">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="reeva-category-card"
          {{ block.shopify_attributes }}
        >
          <div class="reeva-category-image-wrap">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  class: 'reeva-category-image',
                  widths: '300, 450, 600, 750, 900',
                  sizes: '(max-width: 749px) 85vw, (max-width: 989px) 45vw, 25vw',
                  alt: block.settings.title
              }}
            {% else %}
              <div class="reeva-category-placeholder">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="reeva-category-content">
            {% if block.settings.icon_svg != blank %}
              <div class="reeva-category-icon">
                {{ block.settings.icon_svg }}
              </div>
            {% endif %}

            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}

            {% if block.settings.button_label != blank %}
              <span class="reeva-category-link">
                {{ block.settings.button_label }}
                <span aria-hidden="true">→</span>
              </span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.settings.main_button_label != blank %}
      <div class="reeva-category-main-btn-wrap">
        <a href="{{ section.settings.main_button_link | default: '#' }}" class="reeva-category-main-btn">
          {{ section.settings.main_button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  .section-{{ section.id }} {
    background: var(--reeva-bg);
    padding-top: var(--reeva-top);
    padding-bottom: var(--reeva-bottom);
  }

  .section-{{ section.id }} .reeva-category-container {
    width: min(100% - 32px, 1320px);
    margin: 0 auto;
    text-align: center;
  }

  .section-{{ section.id }} .reeva-category-kicker {
    font-family: Verdana, Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--reeva-accent);
    margin-bottom: 18px;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }

  .section-{{ section.id }} .reeva-category-kicker::before,
  .section-{{ section.id }} .reeva-category-kicker::after {
    content: "";
    width: 72px;
    height: 1px;
    background: rgba(184, 145, 85, 0.55);
    display: block;
  }

  .section-{{ section.id }} .reeva-category-heading {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(34px, 4vw, 58px);
    line-height: 1.08;
    font-weight: 500;
    color: var(--reeva-heading);
    margin: 0 0 14px;
  }

  .section-{{ section.id }} .reeva-category-subheading {
    font-family: Verdana, Arial, sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: var(--reeva-text);
    margin: 0 auto 42px;
    max-width: 620px;
  }

  .section-{{ section.id }} .reeva-category-grid-wrap {
    display: grid;
    gap: 26px;
  }

  .section-{{ section.id }} .reeva-grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .section-{{ section.id }} .reeva-grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .section-{{ section.id }} .reeva-category-card {
    background: var(--reeva-card-bg);
    border: 1px solid var(--reeva-border);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 28px rgba(37, 37, 37, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .section-{{ section.id }} .reeva-category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 34px rgba(37, 37, 37, 0.08);
    border-color: rgba(38, 120, 112, 0.35);
  }

  .section-{{ section.id }} .reeva-category-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1.34 / 1;
    overflow: hidden;
    background: #f5efe5;
  }

  .section-{{ section.id }} .reeva-category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .section-{{ section.id }} .reeva-category-card:hover .reeva-category-image {
    transform: scale(1.045);
  }

  .section-{{ section.id }} .reeva-category-placeholder {
    width: 100%;
    height: 100%;
    background: #f5efe5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .section-{{ section.id }} .reeva-category-placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.35;
  }

  .section-{{ section.id }} .reeva-category-content {
    position: relative;
    padding: 34px 26px 26px;
    {% comment %} min-height: 210px; {% endcomment %}
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-{{ section.id }} .reeva-category-icon {
    position: absolute;
    top: -31px;
    left: 26px;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: #fbf7ef;
    border: 1px solid rgba(226, 211, 188, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--reeva-accent);
  }

  .section-{{ section.id }} .reeva-category-icon svg {
    width: 30px;
    height: 30px;
    stroke: currentColor;
  }

  .section-{{ section.id }} .reeva-category-content h3 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 25px;
    line-height: 1.25;
    font-weight: 500;
    color: var(--reeva-heading);
    margin: 0 0 14px;
  }

  .section-{{ section.id }} .reeva-category-content p {
    font-family: Verdana, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.65;
    color: var(--reeva-text);
    margin: 0 0 22px;
    max-width: 250px;
  }

  .section-{{ section.id }} .reeva-category-link {
    margin-top: auto;
    font-family: Verdana, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--reeva-accent);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .section-{{ section.id }} .reeva-category-main-btn-wrap {
    margin-top: 38px;
  }

  .section-{{ section.id }} .reeva-category-main-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 38px;
    border-radius: 6px;
    background: var(--reeva-accent);
    color: #ffffff;
    font-family: Verdana, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .reeva-category-main-btn:hover {
    opacity: 0.92;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .reeva-category-grid-wrap {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: calc(var(--reeva-top) * 0.7);
      padding-bottom: calc(var(--reeva-bottom) * 0.7);
    }

    .section-{{ section.id }} .reeva-category-container {
      width: min(100% - 24px, 1320px);
    }

    .section-{{ section.id }} .reeva-category-kicker {
      font-size: 11px;
      letter-spacing: 3px;
      gap: 10px;
      margin-bottom: 14px;
    }

    .section-{{ section.id }} .reeva-category-kicker::before,
    .section-{{ section.id }} .reeva-category-kicker::after {
      width: 36px;
    }

    .section-{{ section.id }} .reeva-category-heading {
      font-size: 34px;
    }

    .section-{{ section.id }} .reeva-category-subheading {
      font-size: 14px;
      margin-bottom: 28px;
    }

    .section-{{ section.id }} .reeva-category-grid-wrap {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .section-{{ section.id }} .reeva-category-image-wrap {
      aspect-ratio: 1.45 / 1;
    }

    .section-{{ section.id }} .reeva-category-content {
      min-height: auto;
      padding: 32px 22px 24px;
    }

    .section-{{ section.id }} .reeva-category-icon {
      width: 56px;
      height: 56px;
      top: -28px;
      left: 22px;
    }

    .section-{{ section.id }} .reeva-category-content h3 {
      font-size: 24px;
    }

    .section-{{ section.id }} .reeva-category-main-btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Reeva Category Grid",
  "tag": "section",
  "class": "reeva-category-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Small top heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Find your perfect sparkle"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Timeless designs for every style, occasion and moment."
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "default": "4",
      "options": [
        {
          "value": "3",
          "label": "3 columns"
        },
        {
          "value": "4",
          "label": "4 columns"
        }
      ]
    },
    {
      "type": "text",
      "id": "main_button_label",
      "label": "Main button label",
      "default": "Explore All Collections"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f2e8"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#fffaf2"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#282828"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#267870"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border color",
      "default": "#eadcc7"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "SVG icon code",
          "info": "Paste simple SVG code here. Optional."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Rings"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Category description",
          "default": "From dainty bands to statement rings."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Link label",
          "default": "Explore Rings"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reeva Category Grid",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Rings",
            "text": "From dainty bands to statement rings.",
            "button_label": "Explore Rings"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Earrings",
            "text": "Elegant hoops, studs and danglers for every look.",
            "button_label": "Explore Earrings"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Necklaces",
            "text": "Timeless pendants and necklaces to cherish.",
            "button_label": "Explore Necklaces"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Bracelets",
            "text": "Minimal chains to charming bracelets.",
            "button_label": "Explore Bracelets"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Diamond Jewellery",
            "text": "IGI certified diamonds for unmatched brilliance.",
            "button_label": "Explore Diamonds"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Traditional Jewellery",
            "text": "Celebrate heritage with timeless traditional pieces.",
            "button_label": "Explore Traditional"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Nose Pins",
            "text": "Subtle, elegant and perfectly you.",
            "button_label": "Explore Nose Pins"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Gifting",
            "text": "Thoughtful gifts for your special moments.",
            "button_label": "Explore Gifts"
          }
        }
      ]
    }
  ]
}
{% endschema %}