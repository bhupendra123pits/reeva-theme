{% comment %}
  Reeva.life - Bento Collection Grid Section
  File: sections/reeva-bento-collection-grid.liquid
{% endcomment %}

<section
  class="reeva-bento-section section-{{ section.id }}"
  style="
    --reeva-bg: {{ section.settings.background_color }};
    --reeva-heading: {{ section.settings.heading_color }};
    --reeva-text: {{ section.settings.text_color }};
    --reeva-accent: {{ section.settings.accent_color }};
    --reeva-border: {{ section.settings.border_color }};
    --reeva-top: {{ section.settings.padding_top }}px;
    --reeva-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="reeva-bento-container">

    {% if section.settings.kicker != blank %}
      <div class="reeva-bento-kicker">{{ section.settings.kicker }}</div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="reeva-bento-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="reeva-bento-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="reeva-bento-grid">
      {% for block in section.blocks %}
        {% assign collection_obj = block.settings.collection %}
        {% assign card_link = block.settings.link %}

        {% if card_link == blank and collection_obj != blank %}
          {% assign card_link = collection_obj.url %}
        {% endif %}

        <a
          href="{{ card_link | default: '#' }}"
          class="reeva-bento-card reeva-bento-{{ block.settings.card_size }}"
          {{ block.shopify_attributes }}
        >
          <div class="reeva-bento-media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  class: 'reeva-bento-image',
                  widths: '400, 600, 800, 1000, 1200, 1400',
                  sizes: '(max-width: 749px) 92vw, (max-width: 989px) 48vw, 33vw',
                  alt: block.settings.title
              }}
            {% elsif collection_obj.featured_image != blank %}
              {{
                collection_obj.featured_image
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  class: 'reeva-bento-image',
                  widths: '400, 600, 800, 1000, 1200, 1400',
                  sizes: '(max-width: 749px) 92vw, (max-width: 989px) 48vw, 33vw',
                  alt: collection_obj.title
              }}
            {% else %}
              <div class="reeva-bento-placeholder">
                {{ 'collection-3' | placeholder_svg_tag }}
              </div>
            {% endif %}

            <div class="reeva-bento-overlay"></div>

            {% if block.settings.badge != blank %}
              <span class="reeva-bento-badge">{{ block.settings.badge }}</span>
            {% endif %}

            <div class="reeva-bento-content">
              {% if block.settings.title != blank %}
                <h3>{{ block.settings.title }}</h3>
              {% elsif collection_obj != blank %}
                <h3>{{ collection_obj.title }}</h3>
              {% endif %}

              {% if block.settings.text != blank %}
                <p>{{ block.settings.text }}</p>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <span class="reeva-bento-link">
                  {{ block.settings.button_label }}
                  <span aria-hidden="true">→</span>
                </span>
              {% endif %}
            </div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.settings.main_button_label != blank %}
      <div class="reeva-bento-main-btn-wrap">
        <a href="{{ section.settings.main_button_link | default: '#' }}" class="reeva-bento-main-btn">
          {{ section.settings.main_button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  .section-{{ section.id }} {
    background: var(--reeva-bg);
    padding-top: var(--reeva-top);
    padding-bottom: var(--reeva-bottom);
  }

  .section-{{ section.id }} .reeva-bento-container {
    width: min(100% - 32px, 1320px);
    margin: 0 auto;
    text-align: center;
  }

  .section-{{ section.id }} .reeva-bento-kicker {
    font-family: Verdana, Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--reeva-accent);
    margin-bottom: 18px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }

  .section-{{ section.id }} .reeva-bento-kicker::before,
  .section-{{ section.id }} .reeva-bento-kicker::after {
    content: "";
    width: 70px;
    height: 1px;
    background: rgba(184, 145, 85, 0.55);
    display: block;
  }

  .section-{{ section.id }} .reeva-bento-heading {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.08;
    font-weight: 500;
    color: var(--reeva-heading);
    margin: 0 0 14px;
  }

  .section-{{ section.id }} .reeva-bento-subheading {
    font-family: Verdana, Arial, sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: var(--reeva-text);
    max-width: 660px;
    margin: 0 auto 42px;
  }

  .section-{{ section.id }} .reeva-bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 260px;
    gap: 24px;
    grid-auto-flow: dense;
  }

  .section-{{ section.id }} .reeva-bento-card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 18px;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--reeva-border);
    background: #f5efe5;
    box-shadow: 0 12px 30px rgba(37, 37, 37, 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .section-{{ section.id }} .reeva-bento-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(37, 37, 37, 0.11);
    border-color: rgba(38, 120, 112, 0.35);
  }

  .section-{{ section.id }} .reeva-bento-small {
    grid-column: span 1;
    grid-row: span 1;
  }

  .section-{{ section.id }} .reeva-bento-wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  .section-{{ section.id }} .reeva-bento-tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .section-{{ section.id }} .reeva-bento-large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .section-{{ section.id }} .reeva-bento-media {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .section-{{ section.id }} .reeva-bento-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .section-{{ section.id }} .reeva-bento-card:hover .reeva-bento-image {
    transform: scale(1.045);
  }

  .section-{{ section.id }} .reeva-bento-placeholder,
  .section-{{ section.id }} .reeva-bento-placeholder svg {
    width: 100%;
    height: 100%;
  }

  .section-{{ section.id }} .reeva-bento-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5efe5;
  }

  .section-{{ section.id }} .reeva-bento-placeholder svg {
    opacity: 0.35;
  }

  .section-{{ section.id }} .reeva-bento-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.02) 0%,
      rgba(0, 0, 0, 0.14) 45%,
      rgba(0, 0, 0, 0.58) 100%
    );
  }

  .section-{{ section.id }} .reeva-bento-badge {
    position: absolute;
    top: 18px;
    left: 18px;
    z-index: 2;
    background: rgba(255, 250, 242, 0.94);
    color: var(--reeva-accent);
    font-family: Verdana, Arial, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(234, 220, 199, 0.8);
  }

  .section-{{ section.id }} .reeva-bento-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 26px;
    text-align: left;
  }

  .section-{{ section.id }} .reeva-bento-content h3 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(25px, 2vw, 36px);
    line-height: 1.12;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 10px;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }

  .section-{{ section.id }} .reeva-bento-small .reeva-bento-content h3 {
    font-size: 25px;
  }

  .section-{{ section.id }} .reeva-bento-content p {
    font-family: Verdana, Arial, sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 16px;
    max-width: 390px;
  }

  .section-{{ section.id }} .reeva-bento-small .reeva-bento-content p {
    display: none;
  }

  .section-{{ section.id }} .reeva-bento-link {
    font-family: Verdana, Arial, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.75);
    padding-bottom: 4px;
  }

  .section-{{ section.id }} .reeva-bento-main-btn-wrap {
    margin-top: 38px;
  }

  .section-{{ section.id }} .reeva-bento-main-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 38px;
    border-radius: 6px;
    background: var(--reeva-accent);
    color: #ffffff;
    font-family: Verdana, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .reeva-bento-main-btn:hover {
    opacity: 0.92;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .reeva-bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 240px;
      gap: 20px;
    }

    .section-{{ section.id }} .reeva-bento-small,
    .section-{{ section.id }} .reeva-bento-wide,
    .section-{{ section.id }} .reeva-bento-tall,
    .section-{{ section.id }} .reeva-bento-large {
      grid-column: span 1;
      grid-row: span 1;
    }

    .section-{{ section.id }} .reeva-bento-large,
    .section-{{ section.id }} .reeva-bento-wide {
      grid-column: span 2;
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: calc(var(--reeva-top) * 0.7);
      padding-bottom: calc(var(--reeva-bottom) * 0.7);
    }

    .section-{{ section.id }} .reeva-bento-container {
      width: min(100% - 24px, 1320px);
    }

    .section-{{ section.id }} .reeva-bento-kicker {
      font-size: 11px;
      letter-spacing: 3px;
      gap: 10px;
      margin-bottom: 14px;
    }

    .section-{{ section.id }} .reeva-bento-kicker::before,
    .section-{{ section.id }} .reeva-bento-kicker::after {
      width: 34px;
    }

    .section-{{ section.id }} .reeva-bento-heading {
      font-size: 34px;
    }

    .section-{{ section.id }} .reeva-bento-subheading {
      font-size: 14px;
      margin-bottom: 28px;
    }

    .section-{{ section.id }} .reeva-bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 18px;
    }

    .section-{{ section.id }} .reeva-bento-small,
    .section-{{ section.id }} .reeva-bento-wide,
    .section-{{ section.id }} .reeva-bento-tall,
    .section-{{ section.id }} .reeva-bento-large {
      grid-column: span 1;
      grid-row: span 1;
    }

    .section-{{ section.id }} .reeva-bento-media {
      aspect-ratio: 1.15 / 1;
      min-height: 300px;
    }

    .section-{{ section.id }} .reeva-bento-content {
      padding: 22px;
    }

    .section-{{ section.id }} .reeva-bento-content h3,
    .section-{{ section.id }} .reeva-bento-small .reeva-bento-content h3 {
      font-size: 28px;
    }

    .section-{{ section.id }} .reeva-bento-small .reeva-bento-content p {
      display: block;
    }

    .section-{{ section.id }} .reeva-bento-main-btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Reeva Bento Grid",
  "tag": "section",
  "class": "reeva-bento-collection-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Small top heading",
      "default": "Curated Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Explore jewellery by style"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover refined edits for everyday wear, gifting, celebration and timeless personal style."
    },
    {
      "type": "text",
      "id": "main_button_label",
      "label": "Main button label",
      "default": "View All Collections"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f2e8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#282828"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#267870"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border color",
      "default": "#eadcc7"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "If empty, collection featured image will be used."
        },
        {
          "type": "select",
          "id": "card_size",
          "label": "Card size",
          "default": "small",
          "options": [
            {
              "value": "small",
              "label": "Small"
            },
            {
              "value": "wide",
              "label": "Wide"
            },
            {
              "value": "tall",
              "label": "Tall"
            },
            {
              "value": "large",
              "label": "Large"
            }
          ]
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "default": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "default": "Rings"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Elegant pieces designed for effortless styling."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Link label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "If empty, selected collection link will be used."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reeva Bento Collection Grid",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "card_size": "large",
            "badge": "Everyday",
            "title": "Everyday Elegance",
            "text": "Minimal pieces made for daily wear and effortless styling.",
            "button_label": "Shop Everyday"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "card_size": "small",
            "badge": "Classic",
            "title": "Rings",
            "text": "Elegant bands and statement rings.",
            "button_label": "Explore Rings"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "card_size": "small",
            "badge": "Sparkle",
            "title": "Earrings",
            "text": "Studs, hoops and delicate drops.",
            "button_label": "Explore Earrings"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "card_size": "wide",
            "badge": "Gifting",
            "title": "Meaningful Gifts",
            "text": "Thoughtful jewellery picks for birthdays, anniversaries and special occasions.",
            "button_label": "Shop Gifts"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "card_size": "tall",
            "badge": "Premium",
            "title": "Diamond Jewellery",
            "text": "Refined diamond pieces with timeless brilliance.",
            "button_label": "Explore Diamonds"
          }
        }
      ]
    }
  ]
}
{% endschema %}