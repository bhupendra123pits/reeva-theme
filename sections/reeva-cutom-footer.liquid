      </div>
      <div>
        <strong>BIS Hallmarked</strong>
        <span>Assured purity and quality in every piece.</span>
      </div>
    </div>

    <div class="reeva-footer-trust-divider"></div>

    <div class="reeva-footer-trust-item">
      <div class="reeva-footer-trust-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21.5 12a8 8 0 1 1-2.3-5.6"
