<section class="reeva-custom-footer">
  <div class="reeva-footer-main">
    <div class="reeva-footer-brand">
      {% if section.settings.logo_image != blank %}
        {% comment %}
          <img
            src="{{ section.settings.logo_image | image_url: width: 420 }}"
            alt="{{ shop.name }}"
            class="reeva-footer-logo-img"
            loading="lazy"
          >
        {% endcomment %}
      {% else %}
        <div class="reeva-footer-logo-text">{{ section.settings.logo_text }}</div>
      {% endif %}

      {% if section.settings.brand_text != blank %}
        <p class="reeva-footer-brand-text">{{ section.settings.brand_text }}</p>
      {% endif %}

      <div class="reeva-footer-brand-line"></div>

      {% if section.settings.newsletter_heading != blank %}
        <h3 class="reeva-footer-news-heading">{{ section.settings.newsletter_heading }}</h3>
      {% endif %}

      {% if section.settings.newsletter_text != blank %}
        <p class="reeva-footer-news-text">{{ section.settings.newsletter_text }}</p>
      {% endif %}

      {% form 'customer', class: 'reeva-footer-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          class="reeva-footer-email"
          placeholder="Enter your email address"
          required
        >
        <button type="submit" class="reeva-footer-submit">Subscribe</button>
      {% endform %}
    </div>

    <div class="reeva-footer-menu-area">
      {% if section.settings.footer_menu != blank %}
        {% for link in section.settings.footer_menu.links %}
          <div class="reeva-footer-menu-col">
            <h4>{{ link.title }}</h4>
            <div class="reeva-footer-heading-line"></div>

            {% if link.links != blank %}
              <ul>
                {% for child_link in link.links %}
                  <li>
                    <a href="{{ child_link.url }}">{{ child_link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <div class="reeva-footer-trust">
    <div class="reeva-footer-trust-item">
      <div class="reeva-footer-trust-icon">
        <svg class="reeva-diamond-svg" viewBox="80 50 140 150" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <g fill="none" stroke="#3f8984" stroke-width="12" stroke-linecap="round" stroke-linejoin="round">
            <path d="M90 95L120 60H180L210 95L150 190L90 95Z"/>
            <path d="M90 95H210"/>
            <path d="M120 60L150 95L180 60"/>
            <path d="M120 95L150 190L180 95"/>
          </g>
        </svg>
      </div>

      <div>
        <strong>IGI Certified Diamonds</strong>
        <span>Certified brilliance you can trust.</span>
      </div>
    </div>

    <div class="reeva-footer-trust-divider"></div>

    <div class="reeva-footer-trust-item">
      <div class="reeva-footer-trust-icon">
        <svg viewBox="-60 -20 480 300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <g fill="none" stroke="#3f8984" stroke-width="18" stroke-linecap="round" stroke-linejoin="round">
