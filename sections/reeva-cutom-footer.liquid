          {% if section.settings.youtube_url != blank %}
            <a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21.5 7.1s-.2-1.5-.9-2.1c-.8-.9-1.7-.9-2.1-.9C15.6 3.9 12 3.9 12 3.9s-3.6 0-6.5.2c-.4 0-1.3.1-2.1.9-.7.7-.9 2.1-.9 2.1S2.3 8.8 2.3 10.5v1.6c0 1.7.2 3.4.2 3.4s.2 1.5.9 2.1c.8.9 1.9.8 2.4.9 1.7.2 6.2.2 6.2.2s3.6 0 6.5-.2c.4 0 1.3-.1 2.1-.9.7-.7.9-2.1.9-2.1s.2-1.7.2-3.4v-1.6c0-1.7-.2-3.4-.2-3.4ZM10 14.2V8.3l5.6 3-5.6 2.9Z" fill="currentColor"/>
              </svg>
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

<style>
      .reeva-custom-footer {
        background:
          radial-gradient(circle at 12% 20%, rgba(216, 200, 172, 0.18), transparent 30%),
          #fffaf2;
        border-top: 1px solid rgba(216, 200, 172, 0.45);
        color: #1f2024;
      }

      .reeva-footer-main {
        max-width: 1720px;
        margin: 0 auto;
        padding: 88px 90px 64px;
        display: grid;
        grid-template-columns: 1.25fr 2.75fr;
        gap: 90px;
      }

      .reeva-footer-logo-text {
        font-family: Georgia, "Times New Roman", serif;
        color: #3f8984;
        font-size: clamp(48px, 4vw, 72px);
        line-height: 1;
        font-weight: 400;
        letter-spacing: -2px;
      }

      .reeva-footer-logo-img {
        max-width: 300px;
        height: auto;
        display: block;
      }

      .reeva-footer-brand-text {
        margin: 28px 0 0;
        max-width: 390px;
        color: #39404a;
        font-size: 18px;
        line-height: 1.65;
      }

      .reeva-footer-brand-line {
        width: 100%;
        max-width: 390px;
        height: 1px;
        background: rgba(198, 155, 83, 0.42);
        margin: 42px 0 34px;
      }

      .reeva-footer-news-heading {
        margin: 0 0 16px;
        font-family: Georgia, "Times New Roman", serif;
        color: #3f8984;
        font-size: 28px;
        font-weight: 400;
      }

      .reeva-footer-news-text {
        margin: 0 0 28px;
        max-width: 390px;
        color: #39404a;
        font-size: 17px;
        line-height: 1.55;
      }

      .reeva-footer-form {
        display: flex;
        max-width: 430px;
        border: 1px solid rgba(31, 32, 36, 0.18);
        border-radius: 5px;
        overflow: hidden;
        background: #fff;
      }

      .reeva-footer-email {
        flex: 1;
        min-width: 0;
        border: 0;
        padding: 17px 18px;
        font-size: 15px;
        outline: none;
        background: #fff;
        color: #1f2024;
      }

      .reeva-footer-submit {
        border: 0;
        background: #3f8984;
        color: #fff;
        padding: 0 26px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
      }

      .reeva-footer-submit:hover {
        background: #32736f;
      }

      .reeva-footer-menu-area {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 62px;
      }

      .reeva-footer-menu-col h4 {
        margin: 0;
        font-size: 14px;
        letter-spacing: 2.2px;
        text-transform: uppercase;
        color: #1f2024;
        font-weight: 700;
      }

      .reeva-footer-heading-line {
        width: 38px;
        height: 1px;
        background: #c69b53;
        margin: 20px 0 26px;
      }

      .reeva-footer-menu-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .reeva-footer-menu-col li {
        margin-bottom: 16px;
      }

      .reeva-footer-menu-col a {
        color: #2f3742;
        text-decoration: none;
        font-size: 17px;
        line-height: 1.35;
        transition: all 0.2s ease;
      }

      {% comment %} .reeva-footer-menu-col a:hover {
        color: #3f8984;
        padding-left: 4px;
      } {% endcomment %}

      .reeva-footer-trust {
        border-top: 1px solid rgba(216, 200, 172, 0.36);
        border-bottom: 1px solid rgba(216, 200, 172, 0.36);
        background: rgba(255, 250, 242, 0.72);
        padding: 34px 90px;
        display: grid;
        grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
        align-items: center;
        gap: 42px;
      }

      .reeva-footer-trust-item {
        display: flex;
        align-items: center;
        gap: 22px;
      }

      .reeva-footer-trust-icon {
        width: 68px;
        min-width: 68px;
        height: 68px;
        color: #2f7f7a;
      }


      .reeva-footer-trust-icon svg {
        width: 100%;
        height: 100%;
      }

      .reeva-footer-trust-item strong {
        display: block;
        color: #1f2024;
        font-size: 12px;
        margin-bottom: 8px;
        font-weight: 700;
      }

      .reeva-footer-trust-item span {
        display: block;
        color: #4f4f4f;
        font-size: 14px;
        line-height: 1.45;
      }

      .reeva-footer-trust-divider {
        width: 1px;
        height: 70px;
        background: rgba(198, 155, 83, 0.42);
      }

      .reeva-footer-bottom {
        max-width: 1720px;
        margin: 0 auto;
        padding: 26px 90px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .reeva-footer-bottom p {
        margin: 0;
        color: #4f4f4f;
        font-size: 14px;
      }

     .reeva-footer-social {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }

    .reeva-footer-social a {
      width: 36px;
      height: 36px;
      border: 1px solid rgba(63, 137, 132, 0.35);
      border-radius: 50%;
      color: #3f8984;
      background: rgba(255, 255, 255, 0.45);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .reeva-footer-social a svg {
      width: 18px;
      height: 18px;
      display: block;
    }

    .reeva-footer-social a:hover {
      background: #3f8984;
      color: #ffffff;
      border-color: #3f8984;
      transform: translateY(-1px);
    }

      @media screen and (max-width: 1199px) {
        .reeva-footer-main {
          padding: 70px 42px 54px;
          grid-template-columns: 1fr;
          gap: 56px;
        }

        .reeva-footer-menu-area {
          grid-template-columns: repeat(4, 1fr);
          gap: 34px;
        }

        .reeva-footer-menu-col a {
          font-size: 15px;
        }

        .reeva-footer-trust {
          padding: 28px 42px;
          grid-template-columns: 1fr 1fr;
          gap: 28px;
        }

        .reeva-footer-trust-divider {
          display: none;
        }

        .reeva-footer-bottom {
          padding: 24px 42px;
        }
      }

      @media screen and (max-width: 749px) {
        .reeva-footer-main {
          padding: 48px 22px 38px;
          gap: 42px;
        }

        .reeva-footer-logo-text {
          font-size: 48px;
        }

        .reeva-footer-logo-img {
          max-width: 230px;
        }

        .reeva-footer-brand-text {
          font-size: 15px;
          line-height: 1.55;
        }

        .reeva-footer-brand-line {
          margin: 30px 0 26px;
        }

        .reeva-footer-news-heading {
          font-size: 24px;
        }

        .reeva-footer-news-text {
          font-size: 15px;
        }

        .reeva-footer-form {
          max-width: 100%;
        }

        .reeva-footer-email {
          padding: 14px 14px;
          font-size: 14px;
        }

        .reeva-footer-submit {
          padding: 0 18px;
          font-size: 14px;
        }

        .reeva-footer-menu-area {
          grid-template-columns: 1fr 1fr;
          gap: 34px 24px;
        }

        .reeva-footer-menu-col h4 {
          font-size: 12px;
          letter-spacing: 1.7px;
        }

        .reeva-footer-heading-line {
          margin: 14px 0 18px;
        }

        .reeva-footer-menu-col li {
          margin-bottom: 11px;
        }

        .reeva-footer-menu-col a {
          font-size: 14px;
        }

        .reeva-footer-trust {
          padding: 26px 22px;
          grid-template-columns: 1fr;
          gap: 24px;
        }

        .reeva-footer-trust-item {
          gap: 18px;
        }

        .reeva-footer-trust-icon {
          width: 46px;
          min-width: 46px;
          height: 46px;
        }

        .reeva-footer-bottom {
          padding: 22px;
          flex-direction: column;
          align-items: flex-start;
        }

        .reeva-footer-social {
          gap: 16px;
          flex-wrap: wrap;
        }
      }

      @media screen and (max-width: 420px) {
        .reeva-footer-menu-area {
          grid-template-columns: 1fr;
        }

        .reeva-footer-form {
          flex-direction: column;
        }

        .reeva-footer-submit {
          min-height: 48px;
        }
      }
      /* Reeva footer typography - Montserrat */
    .reeva-custom-footer,
    .reeva-custom-footer a,
    .reeva-custom-footer p,
    .reeva-custom-footer span,
    .reeva-custom-footer li,
    .reeva-custom-footer h4 {
      font-family: "Montserrat", sans-serif !important;
    }

    /* Footer column headings */
    .reeva-footer-menu-col h4 {
      font-family: "Montserrat", sans-serif !important;
      font-size: 13px !important;
      line-height: 1.2 !important;
      font-weight: 700 !important;
      letter-spacing: 2.6px !important;
      text-transform: uppercase !important;
    }

    /* Footer menu links */
    .reeva-footer-menu-col a {
      font-family: "Montserrat", sans-serif !important;
      font-size: 14px !important;
      line-height: 1.35 !important;
      font-weight: 400 !important;
      letter-spacing: 0 !important;
    }

    /* Reduce vertical spacing between links */
    .reeva-footer-menu-col li {
      margin-bottom: 11px !important;
    }

    .reeva-footer-trust-item .reeva-diamond-svg {
    transform: scale(.5);
    transform-origin: center;
  }
    .reeva-footer-trust .reeva-truck-svg{
        transform: scale(1.5);
    transform-origin: center;
    }
</style>

{% schema %}
{
  "name": "Reeva Custom Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Footer logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
