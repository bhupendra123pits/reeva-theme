      </div>
      <div>
        <strong>Free Insured Shipping</strong>
        <span>Safe, secure & insured delivery across India.</span>
      </div>
    </div>
  </div>

  <div class="reeva-footer-bottom">
    <p>
      © {{ 'now' | date: '%Y' }}
      {{ shop.name }}. All rights reserved.
    </p>

    {% if section.settings.show_social %}
      {% if section.settings.show_social %}
        <div class="reeva-footer-social" aria-label="Social media links">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="4" y="4" width="16" height="16" rx="4" fill="none" stroke="currentColor" stroke-width="1.7"/>
                <circle cx="12" cy="12" r="3.6" fill="none" stroke="currentColor" stroke-width="1.7"/>
                <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor"/>
              </svg>
            </a>
          {% endif %}

          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M14.2 8.2H16V5.2c-.3 0-1.4-.1-2.7-.1-2.7 0-4.5 1.6-4.5 4.7v2.6H6v3.3h2.8V24h3.4v-8.3H15l.5-3.3h-3.3V10c0-1 .3-1.8 2-1.8Z" fill="currentColor"/>
              </svg>
            </a>
          {% endif %}

          {% if section.settings.pinterest_url != blank %}
            <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12.1 3.2C7.2 3.2 4 6.5 4 10.7c0 2.6 1.4 4.2 2.3 4.2.4 0 .6-1.1.6-1.4 0-.4-.9-1.1-.9-2.6 0-3 2.3-5.2 5.3-5.2 2.6 0 4.6 1.5 4.6 4.2 0 2-1 5.7-3.6 5.7-1 0-1.8-.7-1.8-1.7 0-1.5 1-3 1-4.5 0-2.4-3.4-2-3.4 1 0 .6.1 1.2.4 1.7 0 0-1.4 6-1.7 7.1-.1.5-.1 1.1-.1 1.7 0 .2.3.2.4.1.6-.8 1.5-2.2 1.8-3.2.1-.4.7-2.7.7-2.7.7 1.3 2 2 3.5 2 4.5 0 6.9-4.1 6.9-8 0-3.8-3.3-6.9-7.9-6.9Z" fill="currentColor"/>
