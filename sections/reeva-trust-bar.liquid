<style>
  .reeva-trust-bar {
    width: 100%;
    background: #fffaf2;
    border-top: 1px solid rgba(190, 166, 130, 0.26);
    border-bottom: 1px solid rgba(190, 166, 130, 0.26);
  }

  .reeva-trust-wrapper {
    max-width: 1920px;
    margin: 0 auto;
    padding: 12px 70px;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 34px;
  }

  .reeva-trust-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 13px;
    color: #222326;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
  }

  .reeva-trust-icon {
    width: 46px;
    height: 46px;
    min-width: 46px;
    {% comment %} border: 1.5px solid rgba(63, 137, 132, 0.45); {% endcomment %}
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #3f8984;
    flex: 0 0 auto;
    overflow: hidden;
  }

  .reeva-trust-icon svg {
    width: 30px;
    height: 30px;
    display: block;
    color: inherit;
  }

  .reeva-trust-icon-wide svg {
    width: 36px;
    height: 30px;
  }

  .reeva-trust-divider {
    width: 1px;
    height: 28px;
    background: rgba(196, 151, 82, 0.38);
  }

  @media screen and (min-width: 1200px) and (max-width: 1399px) {
    .reeva-trust-wrapper {
      padding: 10px 48px;
      gap: 24px;
    }

    .reeva-trust-item {
      font-size: 14px;
      gap: 10px;
    }

    .reeva-trust-icon {
      width: 42px;
      height: 42px;
      min-width: 42px;
    }

    .reeva-trust-icon svg {
      width: 42px;
      height: 37px;
    }

    .reeva-trust-icon-wide svg {
      width: 40px;
      height: 40px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 1199px) {
    .reeva-trust-wrapper {
      padding: 18px 36px;
      grid-template-columns: 1fr 1fr;
      gap: 18px 30px;
    }

    .reeva-trust-divider {
      display: none;
    }

    .reeva-trust-item {
      justify-content: flex-start;
      font-size: 15px;
      white-space: normal;
    }

    .reeva-trust-icon {
      width: 44px;
      height: 44px;
      min-width: 44px;
    }

    .reeva-trust-icon svg {
      width: 29px;
      height: 29px;
    }

    .reeva-trust-icon-wide svg {
      width: 36px;
      height: 30px;
    }
  }

  @media screen and (max-width: 749px) {
    .reeva-trust-wrapper {
      padding: 16px;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .reeva-trust-divider {
      display: none;
    }

    .reeva-trust-item {
      justify-content: flex-start;
      gap: 10px;
      font-size: 13.5px;
      line-height: 1.3;
      white-space: normal;
    }

    .reeva-trust-icon {
      width: 40px;
      height: 40px;
      min-width: 40px;
    }

    .reeva-trust-icon svg {
      width: 26px;
      height: 26px;
    }

    .reeva-trust-icon-wide svg {
      width: 33px;
      height: 27px;
    }
  }

  @media screen and (max-width: 420px) {
    .reeva-trust-wrapper {
      grid-template-columns: 1fr;
      padding: 16px 22px;
      gap: 14px;
    }

    .reeva-trust-item {
      font-size: 15px;
      gap: 14px;
    }

    .reeva-trust-icon {
      width: 44px;
      height: 44px;
      min-width: 44px;
    }

    .reeva-trust-icon svg {
      width: 29px;
      height: 29px;
    }

    .reeva-trust-icon-wide svg {
      width: 36px;
      height: 30px;
    }
    
  }
  .reeva-trust-icon .reeva-truck-svg{
        transform: scale(1.5);
    transform-origin: center;
    }
</style>

{% schema %}
{
  "name": "Reeva Trust Bar",
  "presets": [
    {
      "name": "Reeva Trust Bar"
    }
  ]
}
{% endschema %}
