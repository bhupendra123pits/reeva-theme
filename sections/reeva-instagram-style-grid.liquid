{% comment %}
  Reeva.life - Instagram Style Grid
  File: sections/reeva-instagram-style-grid.liquid
{% endcomment %}

<section
  class="reeva-insta section-{{ section.id }}"
  style="
    --reeva-bg: {{ section.settings.background_color }};
    --reeva-heading: {{ section.settings.heading_color }};
    --reeva-text: {{ section.settings.text_color }};
    --reeva-accent: {{ section.settings.accent_color }};
    --reeva-border: {{ section.settings.border_color }};
    --reeva-top: {{ section.settings.padding_top }}px;
    --reeva-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="reeva-insta-container">

    <div class="reeva-insta-header">
      {% if section.settings.kicker != blank %}
        <div class="reeva-insta-kicker">{{ section.settings.kicker }}</div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="reeva-insta-grid">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="reeva-insta-card reeva-insta-{{ block.settings.card_size }}"
          {{ block.shopify_attributes }}
        >
          <div class="reeva-insta-media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1000
                | image_tag:
                  loading: 'lazy',
                  class: 'reeva-insta-image',
                  widths: '300, 500, 700, 900, 1000',
                  sizes: '(max-width: 749px) 50vw, (max-width: 989px) 33vw, 25vw',
                  alt: block.settings.title
              }}
            {% else %}
              <div class="reeva-insta-placeholder">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

            <div class="reeva-insta-overlay">
              <div class="reeva-insta-overlay-content">
                {% if block.settings.icon_svg != blank %}
                  <span class="reeva-insta-icon">
                    {{ block.settings.icon_svg }}
                  </span>
                {% else %}
                  <span class="reeva-insta-icon">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <rect x="4" y="4" width="16" height="16" rx="5" stroke="currentColor" stroke-width="1.8"/>
                      <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.8"/>
                      <circle cx="16.8" cy="7.2" r="1" fill="currentColor"/>
                    </svg>
                  </span>
                {% endif %}

                {% if block.settings.title != blank %}
                  <h3>{{ block.settings.title }}</h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <p>{{ block.settings.text }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.settings.main_button_label != blank %}
      <div class="reeva-insta-btn-wrap">
        <a href="{{ section.settings.main_button_link | default: '#' }}" class="reeva-insta-main-btn">
          {{ section.settings.main_button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  .section-{{ section.id }} {
    background: var(--reeva-bg);
    padding-top: var(--reeva-top);
    padding-bottom: var(--reeva-bottom);
  }

  .section-{{ section.id }} .reeva-insta-container {
    width: min(100% - 32px, 1320px);
    margin: 0 auto;
  }

  .section-{{ section.id }} .reeva-insta-header {
    text-align: center;
    margin-bottom: 42px;
  }

  .section-{{ section.id }} .reeva-insta-kicker {
    font-family: Verdana, Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--reeva-accent);
    margin-bottom: 18px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }

  .section-{{ section.id }} .reeva-insta-kicker::before,
  .section-{{ section.id }} .reeva-insta-kicker::after {
    content: "";
    width: 70px;
    height: 1px;
    background: rgba(184, 145, 85, 0.55);
    display: block;
  }

  .section-{{ section.id }} .reeva-insta-header h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.08;
    font-weight: 500;
    color: var(--reeva-heading);
    margin: 0 0 14px;
  }

  .section-{{ section.id }} .reeva-insta-header p {
    font-family: Verdana, Arial, sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: var(--reeva-text);
    max-width: 660px;
    margin: 0 auto;
  }

  .section-{{ section.id }} .reeva-insta-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 220px;
    gap: 18px;
    grid-auto-flow: dense;
  }

  .section-{{ section.id }} .reeva-insta-card {
    display: block;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid var(--reeva-border);
    background: #f5efe5;
    box-shadow: 0 10px 28px rgba(37, 37, 37, 0.05);
  }

  .section-{{ section.id }} .reeva-insta-small {
    grid-column: span 2;
    grid-row: span 1;
  }

  .section-{{ section.id }} .reeva-insta-tall {
    grid-column: span 2;
    grid-row: span 2;
  }

  .section-{{ section.id }} .reeva-insta-wide {
    grid-column: span 4;
    grid-row: span 1;
  }

  .section-{{ section.id }} .reeva-insta-large {
    grid-column: span 3;
    grid-row: span 2;
  }

  .section-{{ section.id }} .reeva-insta-media {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .section-{{ section.id }} .reeva-insta-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .section-{{ section.id }} .reeva-insta-card:hover .reeva-insta-image {
    transform: scale(1.055);
  }

  .section-{{ section.id }} .reeva-insta-placeholder,
  .section-{{ section.id }} .reeva-insta-placeholder svg {
    width: 100%;
    height: 100%;
  }

  .section-{{ section.id }} .reeva-insta-placeholder {
    background: #f5efe5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .section-{{ section.id }} .reeva-insta-placeholder svg {
    opacity: 0.35;
  }

  .section-{{ section.id }} .reeva-insta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.03) 0%,
      rgba(0, 0, 0, 0.16) 45%,
      rgba(0, 0, 0, 0.58) 100%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
    padding: 22px;
  }

  .section-{{ section.id }} .reeva-insta-card:hover .reeva-insta-overlay {
    opacity: 1;
  }

  .section-{{ section.id }} .reeva-insta-overlay-content {
    color: #ffffff;
    text-align: left;
  }

  .section-{{ section.id }} .reeva-insta-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255, 250, 242, 0.92);
    color: var(--reeva-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .section-{{ section.id }} .reeva-insta-icon svg {
    width: 20px;
    height: 20px;
  }

  .section-{{ section.id }} .reeva-insta-overlay h3 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 24px;
    line-height: 1.15;
    font-weight: 500;
    margin: 0 0 8px;
    color: #ffffff;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.24);
  }

  .section-{{ section.id }} .reeva-insta-overlay p {
    font-family: Verdana, Arial, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    max-width: 320px;
  }

  .section-{{ section.id }} .reeva-insta-btn-wrap {
    text-align: center;
    margin-top: 38px;
  }

  .section-{{ section.id }} .reeva-insta-main-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 38px;
    border-radius: 6px;
    background: var(--reeva-accent);
    color: #ffffff;
    font-family: Verdana, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .reeva-insta-main-btn:hover {
    opacity: 0.92;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .reeva-insta-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 190px;
      gap: 16px;
    }

    .section-{{ section.id }} .reeva-insta-small,
    .section-{{ section.id }} .reeva-insta-tall,
    .section-{{ section.id }} .reeva-insta-wide,
    .section-{{ section.id }} .reeva-insta-large {
      grid-column: span 2;
      grid-row: span 1;
    }

    .section-{{ section.id }} .reeva-insta-large,
    .section-{{ section.id }} .reeva-insta-tall {
      grid-row: span 2;
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: calc(var(--reeva-top) * 0.7);
      padding-bottom: calc(var(--reeva-bottom) * 0.7);
    }

    .section-{{ section.id }} .reeva-insta-container {
      width: min(100% - 24px, 1320px);
    }

    .section-{{ section.id }} .reeva-insta-header {
      margin-bottom: 28px;
    }

    .section-{{ section.id }} .reeva-insta-kicker {
      font-size: 11px;
      letter-spacing: 3px;
      gap: 10px;
      margin-bottom: 14px;
    }

    .section-{{ section.id }} .reeva-insta-kicker::before,
    .section-{{ section.id }} .reeva-insta-kicker::after {
      width: 34px;
    }

    .section-{{ section.id }} .reeva-insta-header h2 {
      font-size: 34px;
    }

    .section-{{ section.id }} .reeva-insta-header p {
      font-size: 14px;
    }

    .section-{{ section.id }} .reeva-insta-grid {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 10px;
      scrollbar-width: none;
    }

    .section-{{ section.id }} .reeva-insta-grid::-webkit-scrollbar {
      display: none;
    }

    .section-{{ section.id }} .reeva-insta-card,
    .section-{{ section.id }} .reeva-insta-small,
    .section-{{ section.id }} .reeva-insta-tall,
    .section-{{ section.id }} .reeva-insta-wide,
    .section-{{ section.id }} .reeva-insta-large {
      flex: 0 0 78%;
      height: 310px;
      scroll-snap-align: start;
      grid-column: auto;
      grid-row: auto;
    }

    .section-{{ section.id }} .reeva-insta-overlay {
      opacity: 1;
      padding: 20px;
    }

    .section-{{ section.id }} .reeva-insta-overlay h3 {
      font-size: 24px;
    }

    .section-{{ section.id }} .reeva-insta-main-btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Reeva Instagram Grid",
  "tag": "section",
  "class": "reeva-instagram-style-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Small top heading",
      "default": "Styled by Reeva.life"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "Jewellery in real moments"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A soft visual edit of everyday sparkle, gifting details and occasion-ready styling."
    },
    {
      "type": "text",
      "id": "main_button_label",
      "label": "Main button label",
      "default": "Follow the Sparkle"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f2e8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#282828"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#267870"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border color",
      "default": "#eadcc7"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Lifestyle image"
        },
        {
          "type": "select",
          "id": "card_size",
          "label": "Card size",
          "default": "small",
          "options": [
            {
              "value": "small",
              "label": "Small"
            },
            {
              "value": "wide",
              "label": "Wide"
            },
            {
              "value": "tall",
              "label": "Tall"
            },
            {
              "value": "large",
              "label": "Large"
            }
          ]
        },
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Custom SVG icon",
          "info": "Optional. Leave blank to use default Instagram-style icon."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Overlay title",
          "default": "Everyday sparkle"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Overlay text",
          "default": "Styled with soft details and timeless jewellery."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reeva Instagram Grid",
      "blocks": [
        {
          "type": "image_card",
          "settings": {
            "card_size": "large",
            "title": "Everyday sparkle",
            "text": "Minimal pieces styled for daily elegance."
          }
        },
        {
          "type": "image_card",
          "settings": {
            "card_size": "small",
            "title": "Golden details",
            "text": "Soft jewellery moments."
          }
        },
        {
          "type": "image_card",
          "settings": {
            "card_size": "small",
            "title": "Gift ready",
            "text": "Wrapped with meaning."
          }
        },
        {
          "type": "image_card",
          "settings": {
            "card_size": "wide",
            "title": "Occasion glow",
            "text": "Jewellery for celebrations and special moments."
          }
        },
        {
          "type": "image_card",
          "settings": {
            "card_size": "tall",
            "title": "Diamond shine",
            "text": "A refined touch of brilliance."
          }
        }
      ]
    }
  ]
}
{% endschema %}