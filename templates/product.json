                "custom_liquid": "<div class=\"reeva-trust-grid\">\n<div class=\"reeva-trust-cell\">\n    <svg class=\"reeva-trust-svg\" viewBox=\"0 0 48 48\" fill=\"none\">\n      <path d=\"M24 6l16 6v10c0 10-7 17-16 20-9-3-16-10-16-20V12l16-6z\" stroke=\"currentColor\" stroke-width=\"3.5\" stroke-linejoin=\"round\"/>\n      <path d=\"M18 24l4 4 8-9\" stroke=\"currentColor\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    </svg>\n    <span>{{ product.metafields.custom.warranty_months }}-Month Warranty</span>\n  </div>\n\n  <div class=\"reeva-trust-cell\">\n    <svg class=\"reeva-trust-svg\" viewBox=\"0 0 48 48\" fill=\"none\">\n      <circle cx=\"24\" cy=\"24\" r=\"20\" stroke=\"currentColor\" stroke-width=\"3.5\"/>\n      <text x=\"24\" y=\"22\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"800\" fill=\"currentColor\">{{ product.metafields.custom.purity }}</text>\n      <text x=\"24\" y=\"32\" text-anchor=\"middle\" font-size=\"9\" font-weight=\"700\" fill=\"currentColor\">{{ product.metafields.custom.metal_type | upcase }}</text>\n    </svg>\n    <span>Fine {{ product.metafields.custom.purity }} {{ product.metafields.custom.metal_type }}</span>\n  </div>\n\n</div>\n\n<style>\n.reeva-trust-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 14px 24px;\n  margin: 20px 0;\n  padding: 16px 0;\n  border-top: 1px solid rgba(190,166,130,0.25);\n  border-bottom: 1px solid rgba(190,166,130,0.25);\n}\n.reeva-trust-cell {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  font-size: 13px;\n  color: #1f2024;\n}\n.reeva-trust-svg {\n  width: 30px;\n  height: 30px;\n  color: #267870;\n  flex-shrink: 0;\n}\n@media screen and (max-width: 749px) {\n  .reeva-trust-svg { width: 26px; height: 26px; }\n  .reeva-trust-cell { font-size: 12px; }\n}\n</style>"
