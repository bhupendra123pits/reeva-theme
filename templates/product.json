            "custom_liquid_T8nkAz": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{% comment %} REEVA — Diamond & Product Specifications (Accordion) {% endcomment %}\n{% assign show_specs = false %}\n{% if product.metafields.custom.shape != blank\n  or product.metafields.custom.diamond_origin != blank\n  or product.metafields.custom.clarity != blank\n  or product.metafields.custom.cut != blank\n  or product.metafields.custom.certificate != blank\n  or product.metafields.custom.metal_type != blank\n  or product.metafields.custom.plating != blank %}\n  {% assign show_specs = true %}\n{% endif %}\n\n{% if show_specs %}\n<details class=\"reeva-diamond-specs\">\n  <summary class=\"reeva-specs-title\">\n    Specifications\n    <span class=\"reeva-specs-toggle\">+</span>\n  </summary>\n\n  <table class=\"reeva-specs-table\">\n    {% if product.metafields.custom.shape != blank %}\n    <tr>\n      <td class=\"reeva-spec-label\">Shape</td>\n      <td class=\"reeva-spec-value\">{{ product.metafields.custom.shape }}</td>\n    </tr>\n    {% endif %}\n\n    {% if product.metafields.custom.diamond_origin != blank %}\n    <tr>\n      <td class=\"reeva-spec-label\">Origin</td>\n      <td class=\"reeva-spec-value\">{{ product.metafields.custom.diamond_origin }}</td>\n    </tr>\n    {% endif %}\n\n    {% if product.metafields.custom.clarity != blank %}\n    <tr>\n      <td class=\"reeva-spec-label\">Clarity</td>\n      <td class=\"reeva-spec-value\">{{ product.metafields.custom.clarity }}</td>\n    </tr>\n    {% endif %}\n\n    {% if product.metafields.custom.cut != blank %}\n    <tr>\n      <td class=\"reeva-spec-label\">Cut</td>\n      <td class=\"reeva-spec-value\">{{ product.metafields.custom.cut }}</td>\n    </tr>\n    {% endif %}\n\n    {% if product.metafields.custom.certificate != blank %}\n    <tr>\n      <td class=\"reeva-spec-label\">Certificate</td>\n      <td class=\"reeva-spec-value\">\n        {{ product.metafields.custom.certificate }}\n        {% if product.metafields.custom.certificate_number != blank %}\n          — {{ product.metafields.custom.certificate_number }}\n        {% endif %}\n      </td>\n    </tr>\n    {% endif %}\n\n    {% if product.metafields.custom.metal_type != blank %}\n    <tr>\n      <td class=\"reeva-spec-label\">Metal Type</td>\n      <td class=\"reeva-spec-value\">{{ product.metafields.custom.metal_type }}</td>\n    </tr>\n    {% endif %}\n\n    {% if product.metafields.custom.plating != blank %}\n    <tr>\n      <td class=\"reeva-spec-label\">Plating</td>\n      <td class=\"reeva-spec-value\">{{ product.metafields.custom.plating }}</td>\n    </tr>\n    {% endif %}\n  </table>\n</details>\n{% endif %}\n\n<style>\n.reeva-diamond-specs {\n  margin-top: 24px;\n  border: 1px solid rgba(190,166,130,0.35);\n  border-radius: 6px;\n  overflow: hidden;\n}\n\n.reeva-specs-title {\n  background: #f9f3ea;\n  padding: 14px 20px;\n  margin: 0;\n  font-size: 13px;\n  font-weight: 600;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  color: #1a3c34;\n  border-bottom: 1px solid rgba(190,166,130,0.35);\n  cursor: pointer;\n  list-style: none;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  user-select: none;\n}\n\n/* Remove default browser triangle arrow on summary */\n.reeva-specs-title::-webkit-details-marker {\n  display: none;\n}\n.reeva-specs-title::marker {\n  content: \"\";\n}\n\n.reeva-specs-toggle {\n  font-size: 16px;\n  font-weight: 400;\n  color: #c69b53;\n  transition: transform 0.2s ease;\n}\n\n/* Rotate + into x-ish / switch to - when open */\n.reeva-diamond-specs[open] .reeva-specs-toggle {\n  transform: rotate(45deg);\n}\n\n.reeva-specs-table {\n  width: 100%;\n  border-collapse: collapse;\n}\n.reeva-specs-table tr {\n  border-bottom: 1px solid rgba(190,166,130,0.2);\n}\n.reeva-specs-table tr:last-child {\n  border-bottom: none;\n}\n.reeva-specs-table tr:nth-child(even) {\n  background: #fdfaf5;\n}\n.reeva-spec-label {\n  padding: 12px 20px;\n  font-size: 13px;\n  font-weight: 600;\n  color: #68686d;\n  width: 40%;\n}\n.reeva-spec-value {\n  padding: 12px 20px;\n  font-size: 13px;\n  color: #1f2024;\n}\n</style>"
